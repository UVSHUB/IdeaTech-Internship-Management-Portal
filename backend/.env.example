# ---- Backend environment variables ----
# Copy to .env for local dev. On Vercel, set these in Project Settings → Environment Variables.

# Server
PORT=5001
NODE_ENV=development

# Database (MongoDB connection string)
DATABASE_URL=

# Auth
JWT_SECRET=

# Secret for Vercel Cron (daily automation checks). Generate a random string.
# Vercel sends it as "Authorization: Bearer <CRON_SECRET>" to /api/cron/daily-checks.
CRON_SECRET=

# Frontend URL (used for verification links & emails) — set to your deployed frontend on Vercel
FRONTEND_URL=http://localhost:3000

# Email (SMTP)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# AI
GEMINI_API_KEY=

# Supabase Storage (all uploads)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CV_BUCKET=ITIMP CV
# Optional: only set to split non-CV files into a separate bucket. Defaults to SUPABASE_CV_BUCKET.
# SUPABASE_FILES_BUCKET=ITIMP Files
