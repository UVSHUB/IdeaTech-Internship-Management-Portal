datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  HR_MANAGER
  TEAM_LEADER
  MENTOR
  INTERN
}

enum InternStatus {
  PENDING
  ACTIVE
  WARNING
  SUSPENDED
  TERMINATED
  COMPLETED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  WORKING
  COMPLETED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  LATE
  HALF_DAY
  ABSENT
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveReason {
  ONE_DAY
  STUDY
  EXAM
  MEDICAL
  PERSONAL
  VACATION
  EMERGENCY
}

enum CertificateType {
  COMPLETION
  EXPERIENCE
  RECOMMENDATION
}

model User {
  id                 String              @id @default(auto()) @map("_id") @db.ObjectId
  email              String              @unique
  passwordHash       String
  firstName          String
  lastName           String
  role               Role
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isTwoFactorEnabled Boolean             @default(false)
  twoFactorSecret    String?
  
  // Relations
  internProfile      InternProfile?      @relation("UserToProfile")
  assignedTasks      Task[]              @relation("AssignedTasks")
  createdTasks       Task[]              @relation("CreatedTasks")
  attendances        Attendance[]
  dailyReports       DailyReport[]       @relation("ReportAuthor")
  reviewedReports    DailyReport[]       @relation("ReportReviewer")
  logbookEntries     Logbook[]           @relation("LogbookAuthor")
  reviewedLogbooks   Logbook[]           @relation("LogbookReviewer")
  createdMeetings    Meeting[]           @relation("CreatedMeetings")
  meetingAttendance  MeetingAttendance[]
  warnings           Warning[]
  leaveRequests      LeaveRequest[]      @relation("LeaveAuthor")
  reviewedLeaves     LeaveRequest[]      @relation("LeaveReviewer")
  certificates       Certificate[]
  notifications      Notification[]
  activityLogs       ActivityLog[]
  projectMembers     ProjectMember[]
  
  // Mentor & Team Lead mappings to interns
  mentorInterns      InternProfile[]     @relation("MentorToInterns")
  leadInterns        InternProfile[]     @relation("LeadToInterns")
}

model Department {
  id             String          @id @default(auto()) @map("_id") @db.ObjectId
  name           String          @unique
  createdAt      DateTime        @default(now())
  internProfiles InternProfile[]
}

model InternProfile {
  id                 String       @id @default(auto()) @map("_id") @db.ObjectId
  userId             String       @unique @db.ObjectId
  user               User         @relation("UserToProfile", fields: [userId], references: [id], onDelete: Cascade)
  internId           String?              // e.g. IT-2026-0001
  nic                String
  dob                DateTime
  university         String
  degree             String
  year               Int
  skills             String
  cvUrl              String
  portfolio          String?
  github             String?
  linkedin           String?
  mobileNumber       String
  address            String
  emergencyContact   String
  positionApplied    String
  departmentId       String       @db.ObjectId
  department         Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  preferredTech      String
  availability       String
  status             InternStatus @default(PENDING)
  level              Int          @default(1)
  xp                 Int          @default(0)
  streak             Int          @default(0)
  completionProgress Float        @default(0.0)
  remainingDays      Int          @default(180)
  warningCount       Int          @default(0)
  lastActive         DateTime     @default(now())
  qrCodeUrl          String?
  idCardUrl          String?
  
  // Supervisor assignments
  mentorId           String?      @db.ObjectId
  mentor             User?        @relation("MentorToInterns", fields: [mentorId], references: [id], onDelete: SetNull)
  teamLeaderId       String?      @db.ObjectId
  teamLeader         User?        @relation("LeadToInterns", fields: [teamLeaderId], references: [id], onDelete: SetNull)

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Project {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  name        String          @unique
  description String?
  githubUrl   String?
  status      String          @default("Active")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  members     ProjectMember[]
  tasks       Task[]
  dailyReports DailyReport[]
}

model ProjectMember {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  projectId String   @db.ObjectId
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Task {
  id          String     @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  description String?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(PENDING)
  dueDate     DateTime
  progress    Float      @default(0.0)
  
  projectId   String?    @db.ObjectId
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  assigneeId  String     @db.ObjectId
  assignee    User       @relation("AssignedTasks", fields: [assigneeId], references: [id], onDelete: Cascade)
  
  createdById String     @db.ObjectId
  createdBy   User       @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Cascade)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Attendance {
  id           String           @id @default(auto()) @map("_id") @db.ObjectId
  userId       String           @db.ObjectId
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date         DateTime // Normalized to midnight
  checkIn      DateTime
  checkOut     DateTime?
  workingHours Float?
  status       AttendanceStatus @default(PRESENT)
  notes        String?

  @@unique([userId, date])
}

model DailyReport {
  id            String         @id @default(auto()) @map("_id") @db.ObjectId
  userId        String         @db.ObjectId
  user          User           @relation("ReportAuthor", fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime // Normalized to midnight
  todayTasks    String
  completedWork String
  problemsFaced String
  hoursWorked   Float
  screenshotUrl String?
  githubLink    String?
  commitLink    String?
  demoLink      String?
  status        ApprovalStatus @default(PENDING)
  remarks       String?
  
  reviewedById  String?        @db.ObjectId
  reviewedBy    User?          @relation("ReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  projectId     String?        @db.ObjectId
  project       Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([userId, date])
}

model Logbook {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  userId         String         @db.ObjectId
  user           User           @relation("LogbookAuthor", fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime // Normalized to midnight
  activities     String
  learning       String
  skillsLearned  String
  challenges     String
  solutions      String
  attachmentUrl  String?
  status         ApprovalStatus @default(PENDING)
  mentorComments String?
  
  reviewedById   String?        @db.ObjectId
  reviewedBy     User?          @relation("LogbookReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([userId, date])
}

model Meeting {
  id          String              @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  agenda      String
  meetingTime DateTime
  platform    String              @default("Google Meet")
  link        String
  recordingUrl String?
  minutes     String?
  
  createdById String              @db.ObjectId
  createdBy   User                @relation("CreatedMeetings", fields: [createdById], references: [id], onDelete: Cascade)
  
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  attendance  MeetingAttendance[]
}

model MeetingAttendance {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  meetingId          String   @db.ObjectId
  meeting            Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId             String   @db.ObjectId
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt           DateTime?
  late               Boolean  @default(false)
  participationScore Float    @default(0.0)
  createdAt          DateTime @default(now())

  @@unique([meetingId, userId])
}

model Warning {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @default(now())
  type      String
  reason    String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model LeaveRequest {
  id           String         @id @default(auto()) @map("_id") @db.ObjectId
  userId       String         @db.ObjectId
  user         User           @relation("LeaveAuthor", fields: [userId], references: [id], onDelete: Cascade)
  reason       LeaveReason
  startDate    DateTime
  endDate      DateTime
  description  String
  documentUrl  String?
  status       ApprovalStatus @default(PENDING)
  
  reviewedById String?        @db.ObjectId
  reviewedBy   User?          @relation("LeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Certificate {
  id              String          @id @default(auto()) @map("_id") @db.ObjectId
  userId          String          @db.ObjectId
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  certificateType CertificateType
  serialNumber    String          @unique
  verificationHash String         @unique
  issuedAt        DateTime        @default(now())
  pdfUrl          String

  createdAt       DateTime        @default(now())
}

model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}
